{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "monorepo": true,
  "rootDirectory": "frontend",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "regions": ["iad1"],
  "functions": {
    "web/**/*.py": {
      "runtime": "python3.9"
    }
  }
}
